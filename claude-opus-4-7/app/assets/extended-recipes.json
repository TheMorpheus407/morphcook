        {"id":"olive-oil","name":{"en":"Olive oil","de":"Olivenöl"},"amount":3,"unit":"tbsp","aisle":"pantry"},
        {"id":"lemon","name":{"en":"Lemon, zested","de":"Zitronenabrieb"},"amount":1,"unit":"pcs","aisle":"produce"}
