      "dish_id": "hummus",
      "name": {"en": "Smooth Hummus", "de": "Cremiger Hummus"},
      "variant_label": {"en": "classic", "de": "klassisch"},
      "diet_label": "vegan",
      "summary": {
        "en": "the trick is peeled chickpeas and a lot of tahini.",
        "de": "der trick: geschälte kichererbsen und viel tahini."
      },
      "contains": ["sesame"],
      "attributes": ["easy"],
      "technique_tags": ["raw"],
      "time_minutes": 25,
      "active_minutes": 20,
      "effort": "easy",
      "servings": 4,
      "calories_per_serving": 240,
      "protein_g": 8,
      "carbs_g": 22,
      "fat_g": 14,
      "ingredients": [
        {"id": "chickpea", "qty": 400, "unit": "g", "name": {"en": "cooked chickpeas", "de": "gekochte Kichererbsen"}},
        {"id": "tahini", "qty": 6, "unit": "tbsp", "name": {"en": "tahini", "de": "Tahini"}},
        {"id": "lemon", "qty": 1, "unit": "piece", "name": {"en": "lemon, juiced", "de": "Zitronensaft"}},
        {"id": "garlic", "qty": 1, "unit": "clove", "name": {"en": "garlic", "de": "Knoblauch"}},
        {"id": "cumin", "qty": 0.5, "unit": "tsp", "name": {"en": "cumin", "de": "Kreuzkümmel"}},
        {"id": "olive-oil", "qty": 2, "unit": "tbsp", "name": {"en": "olive oil", "de": "Olivenöl"}}
      ],
      "steps": [
        {"text": {"en": "Peel chickpeas — pinch each one. Slow. Worth it.", "de": "Kichererbsen schälen — jede einzeln. Langsam. Es lohnt sich."}, "time_minutes": 10},
        {"text": {"en": "Blend tahini + lemon + 2 tbsp ice water until pale.", "de": "Tahini + Zitrone + 2 EL Eiswasser hellig pürieren."}, "time_minutes": 2},
        {"text": {"en": "Add chickpeas, garlic, cumin, salt. Blend 4 min, scrape.", "de": "Kichererbsen, Knoblauch, Kreuzkümmel, Salz dazu. 4 Min pürieren, schaben."}, "time_minutes": 4},
        {"text": {"en": "Bowl, swirl, oil, paprika.", "de": "Anrichten, Mulde, Öl, Paprika."}}
      ]
    },
